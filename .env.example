QINGLUO_CPA_MANAGEMENT_KEY=
QINGLUO_CPA_BASE_URL=http://cli-proxy-api:8317
QINGLUO_SCHEDULER_ENABLED=true
QINGLUO_COLLECTION_INTERVAL_SECONDS=60
QINGLUO_STALE_AFTER_SECONDS=180
QINGLUO_METRIC_RETENTION_DAYS=7
QINGLUO_DATA_DIR=/mnt/nas/docker/ai-console/data
QINGLUO_UFW_ROOT=/host/etc/ufw
QINGLUO_SERVE_LATEST_ONLY=true
QINGLUO_DOCKER_BASE_URL=http://docker-socket-proxy:2375
QINGLUO_OS_RELEASE_PATH=/host/etc/os-release
QINGLUO_SYSTEM_SAMPLE_SECONDS=0.5
QINGLUO_HOSTNAME_PATH=/host/etc/hostname
QINGLUO_HOST_IP=192.168.10.10
QINGLUO_CPA_RETRY_ATTEMPTS=3
QINGLUO_CPA_RETRY_DELAY_SECONDS=0.5
